Se ((aTipUni = "LOC") OU (TIPO_MOVIMENTACAO  = MOVIMENTACAO_TRANSFERENCIA)) {  
     
    aSQL = "SELECT                                                                 \
              CAR.ESTPOS,                                                          \
              CAR.POSTRA,                                                          \
              CAR.TIPCON,                                                          \
              POS.DESPOS,                                                          \
              COALESCE(QPO.QTDQPO, 0) AS QTDQPO,                                   \
              PLV.CODPLV,                                                          \
              COALESCE(QPO.DATQPO, GETDATE()) AS DATQPO                            \
          FROM                                                                     \
              R017CAR CAR                                                          \
              INNER JOIN R017POS POS ON                                            \
                  CAR.ESTPOS = POS.ESTPOS                                          \
                  AND CAR.POSTRA = POS.POSTRA                                      \
                  AND DATFIM >= GETDATE()                                          \
              INNER JOIN R017PLV PLV ON                                            \
                  PLV.ESTPOS = POS.ESTPOS                                          \
              LEFT JOIN (                                                          \
                  SELECT                                                           \
                      ESTPOS,                                                      \
                      POSTRA,                                                      \
                      CODPLV,                                                      \
                      MAX(DATQPO) AS DATQPO,                                       \
                      MAX(QTDQPO) AS QTDQPO                                        \
                  FROM                                                             \
                      R092QPO                                                      \
                  GROUP BY                                                         \
                      ESTPOS,                                                      \
                      POSTRA,                                                      \
                      CODPLV                                                       \
              ) QPO ON                                                             \
                  QPO.ESTPOS = POS.ESTPOS                                          \
                  AND QPO.POSTRA = POS.POSTRA                                      \
                  AND QPO.CODPLV = PLV.CODPLV                                      \
          WHERE 1 = 1";   
}
Senao {

  aSQL = "SELECT                                                            \
          HIE_SOL.pospos,                                                   \
          CAR.ESTPOS,                                                       \
          CAR.POSTRA,                                                       \
          CAR.TIPCON,                                                       \
          POS.DESPOS,                                                       \
          COALESCE(QPO.QTDQPO, 0) AS QTDQPO,                                \
          PVL.CODPLV,                                                       \
          COALESCE(QPO.DATQPO, GETDATE()) AS DATQPO                         \
      FROM R017CAR CAR                                                      \
      INNER JOIN R034FUN FUN_SOL                                            \
          ON (FUN_SOL.NUMEMP ="+aNumEmp+"                                          \
          AND FUN_SOL.TIPCOL = 1                                            \
          AND FUN_SOL.NUMCAD = "+aNumCad+")                                    \
      INNER JOIN R017HIE HIE_SOL                                            \
          ON HIE_SOL.ESTPOS = FUN_SOL.ESTPOS                                \
         AND HIE_SOL.POSTRA = FUN_SOL.POSTRA                                \
         AND HIE_SOL.CODTHP = 1                                             \
         AND HIE_SOL.REVHIE = (                                             \
             SELECT MAX(TAB2.REVHIE)                                        \
             FROM R017HIE TAB2                                              \
             WHERE TAB2.ESTPOS = FUN_SOL.ESTPOS                             \
               AND TAB2.POSTRA = FUN_SOL.POSTRA                             \
               AND TAB2.CODTHP = HIE_SOL.CODTHP                             \
         )                                                                  \
      INNER JOIN R017POS POS                                                \
          ON CAR.ESTPOS = POS.ESTPOS                                        \
         AND CAR.POSTRA = POS.POSTRA                                        \
      INNER JOIN R017HIE HIE_POS                                            \
          ON HIE_POS.ESTPOS = CAR.ESTPOS                                    \
         AND HIE_POS.POSTRA = CAR.POSTRA                                    \
         AND HIE_POS.CODTHP = 1                                             \
         AND HIE_POS.REVHIE = (                                             \
             SELECT MAX(TAB2.REVHIE)                                        \
             FROM R017HIE TAB2                                              \
             WHERE TAB2.ESTPOS = CAR.ESTPOS                                 \
               AND TAB2.POSTRA = CAR.POSTRA                                 \
               AND TAB2.CODTHP = HIE_POS.CODTHP                             \
         )                                                                  \
      LEFT JOIN (                                                           \
          SELECT                                                            \
              R092QPO.ESTPOS,                                               \
              R092QPO.POSTRA,                                               \
              R092QPO.CODPLV,                                               \
              MAX(R092QPO.DATQPO) AS DATQPO,                                \
              MAX(R092QPO.QTDQPO) AS QTDQPO                                 \
          FROM R092QPO, R017PLV                                             \
          WHERE R092QPO.estpos = R017PLV.estpos                             \
            AND R092QPO.codplv = R017PLV.codplv                             \
            AND R017PLV.datter >= GETDATE()                                 \
          GROUP BY                                                          \
              R092QPO.ESTPOS,                                               \
              R092QPO.POSTRA,                                               \
              R092QPO.CODPLV                                                \
      ) QPO                                                                 \
          ON QPO.ESTPOS = POS.ESTPOS                                        \
         AND QPO.POSTRA = POS.POSTRA                                        \
      INNER JOIN R017PLV PVL                                                \
          ON (PVL.estpos = QPO.estpos                                       \
          AND PVL.codplv = QPO.codplv)                                       \           \
      WHERE ISNULL(HIE_POS.pospos, '') LIKE CONCAT(ISNULL(HIE_SOL.POSPOS, ''), '%')"   ;

}
 
 
 
      
