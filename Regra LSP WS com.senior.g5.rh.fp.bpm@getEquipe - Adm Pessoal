Funcao RetornaAtsDescontosFolhaAnterior(Numero pNumEmp, Numero pTipCol, Numero pNumCad, Numero End pValAts, Numero End pValDes);
{

   /*
       Renan Roberto Raimundo
       Retorna  VALOR ATS e desconto 
       ultima comptencia anterior
       caso na comptencia anteior a do mes n~çao tenha nada calculo de folha
       retorna a ultima compentencia calculada
   
   */
   Definir Alfa aCurAux;
   pValDes = 0;
   pValAts = 0;
   nValAts = 0;
   nValDes = 0;
   
   
   
   Sql_Criar(aCurAux);
   Sql_UsarAbrangencia(aCurAux,0);
   Sql_UsarSqlSenior2(aCurAux,0);                                                            
   Sql_DefinirComando(aCurAux, "SELECT                                                              \
                                CAL.PERREF,                                                         \
                                VER.NUMEMP,                                                         \
                                VER.TIPCOL,                                                         \
                                VER.NUMCAD,                                                         \
                                SUM(CASE WHEN CAL.TIPCAL = 11 AND EVC.TIPEVE = 3                    \
                                         THEN VER.VALEVE ELSE 0 END) AS TOTALDESC,            \
                                SUM(CASE WHEN CAL.TIPCAL IN (11,12,13) AND EVC.USU_EVEATS = 'S'     \
                                         THEN VER.VALEVE ELSE 0 END) AS TOTALATS           \
                            FROM R046VER AS VER                                                     \
                            JOIN R044CAL AS CAL                                                     \
                              ON CAL.NUMEMP = VER.NUMEMP                                            \
                             AND CAL.CODCAL = VER.CODCAL                                            \
                            JOIN R008EVC AS EVC                                                     \
                              ON EVC.CODTAB = VER.TABEVE                                            \
                             AND EVC.CODEVE = VER.CODEVE                                            \
                            WHERE VER.NUMEMP = :NUMEMP                                               \
                              AND VER.TIPCOL = :TIPCOL                                               \
                              AND VER.NUMCAD = :NUMCAD                                               \
                              AND (                                                                 \
                                    (CAL.TIPCAL = 11 AND EVC.TIPEVE = 3)                            \
                                 OR (CAL.TIPCAL IN (11,12,13) AND EVC.USU_EVEATS = 'S')             \
                              )                                                                     \
                              AND CAL.PERREF =                                                      \
                                  ISNULL(                                                           \
                                                                                                    \
                                    (                                                               \
                                      SELECT MAX(CAL2.PERREF)                                       \
                                      FROM R046VER AS VER2                                          \
                                      JOIN R044CAL AS CAL2                                          \
                                        ON CAL2.NUMEMP = VER2.NUMEMP                                \
                                       AND CAL2.CODCAL = VER2.CODCAL                                \
                                      JOIN R008EVC AS EVC2                                          \
                                        ON EVC2.CODTAB = VER2.TABEVE                                \
                                       AND EVC2.CODEVE = VER2.CODEVE                                \
                                      WHERE VER2.NUMEMP = VER.NUMEMP                                \
                                        AND VER2.TIPCOL = VER.TIPCOL                                \
                                        AND VER2.NUMCAD = VER.NUMCAD                                \
                                        AND (                                                       \
                                              (CAL2.TIPCAL = 11 AND EVC2.TIPEVE = 3)                \
                                           OR (CAL2.TIPCAL IN (11,12,13) AND EVC2.USU_EVEATS = 'S')  \
                                        )                                                            \
                                        AND CAL2.PERREF <= DATEFROMPARTS(                            \
                                                               YEAR(DATEADD(MONTH,-1,GETDATE())),    \
                                                               MONTH(DATEADD(MONTH,-1,GETDATE())), 1) \
                                    ),                                                                \
                                                                                                       \
                                    (                                                                  \
                                      SELECT MIN(CAL3.PERREF)                                          \
                                      FROM R046VER AS VER3                                             \
                                      JOIN R044CAL AS CAL3                                             \
                                        ON CAL3.NUMEMP = VER3.NUMEMP                                   \
                                       AND CAL3.CODCAL = VER3.CODCAL                                   \
                                      JOIN R008EVC AS EVC3                                             \
                                        ON EVC3.CODTAB = VER3.TABEVE                                   \
                                       AND EVC3.CODEVE = VER3.CODEVE                                   \
                                      WHERE VER3.NUMEMP = VER.NUMEMP                                   \
                                        AND VER3.TIPCOL = VER.TIPCOL                                   \
                                        AND VER3.NUMCAD = VER.NUMCAD                                   \
                                        AND (                                                          \
                                              (CAL3.TIPCAL = 11 AND EVC3.TIPEVE = 3)                    \
                                           OR (CAL3.TIPCAL IN (11,12,13) AND EVC3.USU_EVEATS = 'S')     \
                                        )                                                               \
                                        AND CAL3.PERREF >= DATEFROMPARTS(                               \
                                                               YEAR(DATEADD(MONTH,-1,GETDATE())),       \
                                                               MONTH(DATEADD(MONTH,-1,GETDATE())), 1)   \
                                    )                                                                   \
                                  )                                                                     \
                            GROUP BY                                                                    \
                                CAL.PERREF,                                                             \
                                VER.NUMEMP,                                                             \
                                VER.TIPCOL,                                                              \
                                VER.NUMCAD") ;


   SQl_DefinirInteiro(aCurAux, "NUMEMP", pNumEmp);
   SQl_DefinirInteiro(aCurAux, "TIPCOL", pTipCol);
   SQl_DefinirInteiro(aCurAux, "NUMCAD", pNumCad);
   Sql_AbrirCursor(aCurAux);
   Se (SQL_EOF( aCurAux) = 0) {
      
       Sql_RetornarFlutuante(aCurAux, "TOTALDESC",nValDes);
       Sql_RetornarFlutuante(aCurAux, "TOTALATS" ,nValAts);
   }  
   Sql_FecharCursor(aCurAux);
   Sql_Destruir(aCurAux);
  
   pValAts =   nValAts;
   pValDes =   nValDes; 
   
   

}


