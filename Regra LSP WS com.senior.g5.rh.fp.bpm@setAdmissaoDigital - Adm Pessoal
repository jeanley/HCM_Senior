HttpAlteraCodifCaracPadrao(aHTTP, "utf-8");
HttpDesabilitaErroResposta(aHTTP);
HttpPost(aHTTP, aURLPreAdmissionSend, aBody, aRetorno);
HttpLeCodigoResposta(aHTTP, nCodigo);

Se((nCodigo = 200) Ou (nCodigo = 201))
{
 
  getJSONString(aRetorno, "result", aResult);
  getJSONString(aResult, "message", aMessage);
  
  aMessage = "Sucesso";
  setAdmissaoDigital.sretorno = aMessage;
}
Senao
Se(nCodigo = 400){
  PosicaoAlfa ("message", aRetorno, nPosIni);
  PosicaoAlfa ("errorCode", aRetorno, nPosFim);         
  
  nPosIni = nPosIni + 10;
  nPosFim = nPosFim - 16;
  
  CopiarAlfa (aRetorno, nPosIni, nPosFim);
  
  setAdmissaoDigital.sretorno = aRetorno;
}
Senao
setAdmissaoDigital.sretorno = "Erro ao enviar o convite";




