@Tratamento do retorno para obter o bearer token@
PosicaoAlfa("access_token",aToken, nPosIni);
PosicaoAlfa("refresh_token",aToken, nPosFim);

nPos = nPosFim - nPosIni;

CopiarAlfa(aToken, nPosIni, nPos);

TrocaString(aToken,"access_token", "", aToken);     
