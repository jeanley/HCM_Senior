  ALFAPARAINT(aminutossem,nminutossem); 
  ncarsem = (nhorassem * 60) + nminutossem;                        
  ahorassem = ""; 
  aminutossem = ""; 
  
  @Converte Hora Mensal de hh:mm em inteiro@
  ncarmes = ncarsem * 4.5;  
  ahorasmes = ""; 
  aminutosmes = ""; 
  
  ntotmes = ntotmes + ncarmes;
  ntotsem = ntotsem + ncarsem;     

  
