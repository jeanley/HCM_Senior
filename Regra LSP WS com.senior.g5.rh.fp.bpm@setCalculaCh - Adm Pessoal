  {    
    EXECSQL "INSERT INTO USU_TEMPCH2                                                \
          (USU_NUMEMP, USU_TIPCOL, USU_NUMCAD, USU_CODAPF, USU_HORSEM, USU_HORMES)\ 
          VALUES                                                                  \
          (:NNUMEMP, :NTIPCOL, :NNUMCAD, :NCODAPF, :NCARSEM, :NCARMES)";
  }
  se(atipope = "Excluir")
  {
    EXECSQLEX ("DELETE USU_TEMPCH2 WHERE         \                                 
           USU_NUMEMP = :NNUMEMP AND             \
           USU_TIPCOL = :NTIPCOL AND             \
           USU_NUMCAD = :NNUMCAD AND             \
           USU_CODAPF = :NCODAPF",NERRO, AERRO);
  }
  se(atipope = "Alterar")
  {
    EXECSQLEX ("UPDATE USU_TEMPCH2 SET USU_HORSEM = :NCARSEM,     \
                                       USU_HORMES = :NCARMES      \                      
                    WHERE                                         \
                    USU_NUMEMP = :NNUMEMP AND                     \
                    USU_TIPCOL = :NTIPCOL AND                     \
                    USU_NUMCAD = :NNUMCAD AND                     \
                    USU_CODAPF = :NCODAPF",NERRO, AERRO);
   
    
  }
        
} @Final enquanto da lista de entrada @ 


