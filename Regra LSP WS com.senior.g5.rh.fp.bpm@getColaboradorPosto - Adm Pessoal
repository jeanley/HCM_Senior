  Se ((aTipMov  <> "") e (aTipMov <> " ")) {
  
     ANOMFUN = ANOMFUN + " | " + aQualPos ;
  
  }

  @ Parametros de Saída @
  getColaboradorPosto.colaboradores.CRIARLINHA();  
  getColaboradorPosto.colaboradores.snumemp = ANUMEMP;
  getColaboradorPosto.colaboradores.stipcol = ATIPCOL;
