@ Histórico de salário @
ASQL = "SELECT R034FUN.NUMEMP,    \
       R034FUN.TIPCOL,           \
       R034FUN.NUMCAD,           \
       R034FUN.NOMFUN,           \
       R034FUN.SITAFA,           \
       R034FUN.DATAFA,           \
       R010SIT.DESSIT,           \
       R017POS.POSTRA,           \
       R017POS.DESPOS,           \
       R024CAR.CODCAR,          \
       R024CAR.titcar,          \
       R018CCU.codccu,          \
       R018CCU.nomccu,          \
       R034FUN.tipcon,          \
       R006ESC.HORSEM,  \
       R006ESC.HORMES,  \
       R006ESC.USU_NomCom ,  \
       R014SIN.usu_carhor      \
       FROM R034FUN                      \
         INNER JOIN R010SIT  ON (R034FUN.SITAFA = R010SIT.CODSIT)  \        
         INNER JOIN R017POS  ON (R034FUN.ESTPOS = R017POS.ESTPOS AND R034FUN.POSTRA = R017POS.POSTRA) \  
         INNER JOIN R024CAR  ON (R034FUN.ESTCAR = R024CAR.ESTCAR AND R034FUN.CODCAR = R024CAR.CODCAR) \
         INNER JOIN R018CCU ON (R034FUN.NUMEMP = R018CCU.NUMEMP AND R034FUN.CODCCU = R018CCU.CODCCU)  \
         INNER JOIN R006ESC ON (R034FUN.CODESC = R006ESC.CODESC )         \
         LEFT JOIN R038HSI HI                                            \
          ON HI.NUMEMP = R034FUN.NUMEMP                                      \
           AND HI.TIPCOL = R034FUN.TIPCOL                                      \
           AND HI.NUMCAD = R034FUN.NUMCAD                                      \
           AND HI.DATALT = (                                              \
              SELECT MAX(DAT.DATALT)                                     \
              FROM R038HSI DAT                                           \
              WHERE DAT.NUMEMP = HI.NUMEMP                               \
                AND DAT.TIPCOL = HI.TIPCOL                               \
                AND DAT.NUMCAD = HI.NUMCAD)                              \
         INNER JOIN R014SIN  ON (R014SIN.CODSIN = HI.CODSIN)  \    
          WHERE  R034FUN.TIPCOL = 1 AND ((R034FUN.SITAFA <> 7  )  OR (R034FUN.SITAFA = 7 AND  R034FUN.DATAFA >= CONVERT(date, '01/01/2023', 103))) \                                                                
          ##CONDAUX##";
        
                                  
ASQL = "SELECT                                                             \
       R034FUN.NUMEMP,                                                     \
       R034FUN.TIPCOL,                                                     \
       R034FUN.NUMCAD,                                                     \
       R034FUN.NOMFUN,                                                     \
       R034FUN.SITAFA,                                                     \
       R034FUN.DATAFA,                                                     \
       R010SIT.DESSIT,                                                     \
       R017POS.POSTRA,                                                     \
       R038HPO.postra AS POSHPO,                                           \
       R017POS.DESPOS,                                                     \
       R024CAR.CODCAR,                                                     \
       R024CAR.TITCAR,                                                     \
       R018CCU.CODCCU,                                                     \
       R018CCU.NOMCCU,                                                     \
       R034FUN.TIPCON,                                                     \
       R006ESC.HORSEM,                                                     \
       R006ESC.HORMES,                                                     \
       R006ESC.USU_NomCom,                                                 \
       R014SIN.USU_CARHOR                                                  \
FROM   R034FUN                                                             \ 
       INNER JOIN R038HPO                                                  \
               ON R038HPO.NUMEMP = R034FUN.NUMEMP                          \
              AND R038HPO.TIPCOL = R034FUN.TIPCOL                          \
              AND R038HPO.NUMCAD = R034FUN.NUMCAD                          \
              AND R038HPO.INIATU = (                                       \
                  SELECT MAX(TAB1.INIATU)                                  \
                  FROM   R038HPO TAB1                                      \
                  WHERE  TAB1.NUMEMP = R034FUN.NUMEMP                      \
                    AND  TAB1.TIPCOL = R034FUN.TIPCOL                      \
                    AND  TAB1.NUMCAD = R034FUN.NUMCAD                      \
                    AND  TAB1.iniatu < :CMPREF) \
       INNER JOIN R010SIT                                                  \
               ON R034FUN.SITAFA = R010SIT.CODSIT                          \
       INNER JOIN R017POS                                                  \
               ON R038HPO.ESTPOS = R017POS.ESTPOS                          \
              AND R038HPO.POSTRA = R017POS.POSTRA                          \
       INNER JOIN R024CAR                                                  \
               ON R034FUN.ESTCAR = R024CAR.ESTCAR                          \
              AND R034FUN.CODCAR = R024CAR.CODCAR                          \
       INNER JOIN R018CCU                                                  \
               ON R034FUN.NUMEMP = R018CCU.NUMEMP                          \
              AND R034FUN.CODCCU = R018CCU.CODCCU                          \
       INNER JOIN R006ESC                                                  \
               ON R034FUN.CODESC = R006ESC.CODESC                          \
                                                                           \
       LEFT JOIN R038HSI HI                                                \
              ON HI.NUMEMP = R034FUN.NUMEMP                                \
             AND HI.TIPCOL = R034FUN.TIPCOL                                \
             AND HI.NUMCAD = R034FUN.NUMCAD                                \
             AND HI.DATALT = (                                             \
                 SELECT MAX(DAT.DATALT)                                    \
                 FROM   R038HSI DAT                                        \
                 WHERE  DAT.NUMEMP = HI.NUMEMP                             \
                   AND  DAT.TIPCOL = HI.TIPCOL                             \
                   AND  DAT.NUMCAD = HI.NUMCAD                             \
             )                                                             \
       INNER JOIN R014SIN                                                  \
               ON R014SIN.CODSIN = HI.CODSIN                               \
WHERE  R034FUN.TIPCOL = 1                                                  \
  AND  (R034FUN.SITAFA <> 7                                                \
        OR (R034FUN.SITAFA = 7                                             \
  AND R034FUN.DATAFA >= CONVERT(DATE, '01/01/2023', 103)))     \
   ##CONDAUX##" ;
   
   
Se ((aTipMov  <> "") e (aTipMov <> " ")) {
  ASQL = "SELECT                                                                                         \                                                                                
      R034FUN.NUMEMP,                                                                                     \ 
      R034FUN.TIPCOL,                                                                                     \
      R034FUN.NUMCAD,                                                                                     \
      R034FUN.NOMFUN,                                                                                     \
      R034FUN.SITAFA,                                                                                      \
      R034FUN.DATAFA,                                                                                       \
      S.DESSIT,                                                                                             \
      P.POSTRA,                                                                                              \
      P.DESPOS,                                                                                               \
      CASE WHEN HR.QUAL_POSTO = 'ANTERIOR' THEN HR.CODCAR_ANT ELSE C.CODCAR END AS CODCAR,                     \
      CASE WHEN HR.QUAL_POSTO = 'ANTERIOR' THEN C_ANT.TITCAR   ELSE C.TITCAR   END AS TITCAR,                  \
      CASE WHEN HR.QUAL_POSTO = 'ANTERIOR' THEN HR.CODCCU_ANT  ELSE CC.CODCCU  END AS CODCCU,                  \
      CASE WHEN HR.QUAL_POSTO = 'ANTERIOR' THEN CC_ANT.NOMCCU  ELSE CC.NOMCCU  END AS NOMCCU,                  \
      CASE WHEN HR.QUAL_POSTO = 'ANTERIOR' THEN HR.NOMSIN_ANT    ELSE SIN.NOMSIN    END AS NOMSIN,             \
      CASE WHEN HR.QUAL_POSTO = 'ANTERIOR' THEN HR.USU_CARHOR_ANT ELSE SIN.USU_CARHOR END AS USU_CARHOR,       \
      CASE WHEN HR.QUAL_POSTO = 'ANTERIOR' THEN HR.TIPCON_ANT    ELSE R034FUN.TIPCON      END AS TIPCON,       \
      E.HORSEM,                                                                                                \
      E.HORMES,                                                                                                 \
      E.USU_NomCom,                                                                                             \
      HR.QUAL_POSTO                                                                                             \
  FROM R034FUN                                                                                                  \
  INNER JOIN (                                                                                                   \
                                                                                                   \
      SELECT                                                                                                     \
          H1.NUMEMP,                                                                                             \
          H1.TIPCOL,                                                                                             \
          H1.NUMCAD,                                                                                             \
          H1.ESTPOS,                                                                                             \
          H1.POSTRA,                                                                                             \
          NULL        AS CODCCU_ANT,                                                                             \
          NULL        AS CODCAR_ANT,                                                                             \
          NULL        AS ESTCAR_ANT,                                                                             \
          NULL        AS TIPCON_ANT,                                                                             \
          NULL        AS CODSIN_ANT,                                                                             \
          NULL        AS NOMSIN_ANT,                                                                             \
          NULL        AS USU_CARHOR_ANT,                                                                         \
          'ATUAL'     AS QUAL_POSTO                                                                              \
      FROM R038HPO H1                                                                                            \
      WHERE H1.INIATU = (                                                                                        \
          SELECT MAX(H.INIATU)                                                                                   \
          FROM R038HPO H                                                                                         \
          WHERE H.NUMEMP = H1.NUMEMP                                                                             \
            AND H.TIPCOL = H1.TIPCOL                                                                             \
            AND H.NUMCAD = H1.NUMCAD                                                                             \
      )                                                                                                          \
                                                                                                                 \
      UNION ALL                                                                                                  \
      SELECT                                                                                                     \
          H2.NUMEMP,                                                                                             \
          H2.TIPCOL,                                                                                             \
          H2.NUMCAD,                                                                                             \
          H2.ESTPOS,                                                                                             \
          H2.POSTRA,                                                                                             \
          CAR.CODCCU             AS CODCCU_ANT,                                                                  \
          CAR.CODCAR             AS CODCAR_ANT,                                                                  \
          CAR.ESTCAR             AS ESTCAR_ANT,                                                                  \
          CAR.TIPCON             AS TIPCON_ANT,                                                                  \
          CAR.CODSIN             AS CODSIN_ANT,                                                                  \
          SIN_A.NOMSIN           AS NOMSIN_ANT,                                                                  \
          SIN_A.USU_CARHOR       AS USU_CARHOR_ANT,                                                              \
          'ANTERIOR'             AS QUAL_POSTO                                                                   \
      FROM R038HPO H2                                                                                            \
      OUTER APPLY (                                                                                              \
          SELECT TOP (1) C.*                                                                                     \
          FROM R017CAR C                                                                                         \
          WHERE C.ESTPOS = H2.ESTPOS                                                                             \
            AND C.POSTRA = H2.POSTRA                                                                             \
            AND C.DATINI <= H2.INIATU                                                                            \
            AND (                                                                                                \
                  C.DATFIM = CONVERT(date,'31/12/1900',103)                                                      \
               OR C.DATFIM > H2.INIATU                                                                           \
            )                                                                                                    \
          ORDER BY C.DATINI DESC                                                                                 \
      ) CAR                                                                                                      \
      LEFT JOIN R014SIN SIN_A                                                                                    \
        ON SIN_A.CODSIN = CAR.CODSIN                                                                             \
      WHERE H2.INIATU = (                                                                                        \
          SELECT MAX(H.INIATU)                                                                                   \
          FROM R038HPO H                                                                                         \
          WHERE H.NUMEMP = H2.NUMEMP                                                                             \
            AND H.TIPCOL = H2.TIPCOL                                                                             \
            AND H.NUMCAD = H2.NUMCAD                                                                             \
            AND H.INIATU < (                                                                                     \
                SELECT MAX(H3.INIATU)                                                                            \
                FROM R038HPO H3                                                                                  \
                WHERE H3.NUMEMP = H2.NUMEMP                                                                      \
                  AND H3.TIPCOL = H2.TIPCOL                                                                      \
                  AND H3.NUMCAD = H2.NUMCAD                                                                      \
            )                                                                                                    \
      )                                                                                                          \
  ) HR                                                                                                           \
        ON HR.NUMEMP = R034FUN.NUMEMP                                                                            \
       AND HR.TIPCOL = R034FUN.TIPCOL                                                                            \
       AND HR.NUMCAD = R034FUN.NUMCAD                                                                            \
                                                                                                                 \
  INNER JOIN R010SIT S                                                                                           \
          ON R034FUN.SITAFA = S.CODSIT                                                                           \
  INNER JOIN R017POS P                                                                                           \
          ON HR.ESTPOS = P.ESTPOS                                                                                \
         AND HR.POSTRA = P.POSTRA                                                                                 \
  INNER JOIN R024CAR C                                                                                           \
          ON R034FUN.ESTCAR = C.ESTCAR                                                                           \
         AND R034FUN.CODCAR = C.CODCAR                                                                           \
                                                                                                                 \
                                                                                                                 \
  INNER JOIN R018CCU CC                                                                                          \
          ON R034FUN.NUMEMP = CC.NUMEMP                                                                          \
         AND R034FUN.CODCCU = CC.CODCCU                                                                           \
                                                                                                                  \
  LEFT  JOIN R018CCU CC_ANT                                                                                       \
          ON CC_ANT.NUMEMP = R034FUN.NUMEMP                                                                       \
         AND CC_ANT.CODCCU = HR.CODCCU_ANT                                                                        \
  LEFT  JOIN R024CAR C_ANT                                                                                        \
          ON C_ANT.ESTCAR = HR.ESTCAR_ANT                                                                         \
         AND C_ANT.CODCAR = HR.CODCAR_ANT                                                                         \
                                                                                                                  \
  INNER JOIN R006ESC E                                                                                            \
          ON R034FUN.CODESC = E.CODESC                                                                            \
                                                                                                                  \
                                                                                                                  \
  LEFT  JOIN R038HSI HI                                                                                           \
          ON HI.NUMEMP = R034FUN.NUMEMP                                                                           \
         AND HI.TIPCOL = R034FUN.TIPCOL                                                                           \
         AND HI.NUMCAD = R034FUN.NUMCAD                                                                           \
         AND HI.DATALT = (                                                                                        \
              SELECT MAX(DAT.DATALT)                                                                              \
              FROM R038HSI DAT                                                                                    \
              WHERE DAT.NUMEMP = HI.NUMEMP                                                                        \
                AND DAT.TIPCOL = HI.TIPCOL                                                                        \
                AND DAT.NUMCAD = HI.NUMCAD                                                                        \
         )                                                                                                        \
  INNER JOIN R014SIN SIN                                                                                          \
          ON SIN.CODSIN = HI.CODSIN                                                                               \
                                                                                                                  \
  WHERE                                                                                                           \
      R034FUN.TIPCOL = 1                                                                                          \
    AND (                                                                                                         \
          R034FUN.SITAFA <> 7                                                                                     \
       OR (R034FUN.SITAFA = 7 AND R034FUN.DATAFA >= CONVERT(date,'01/01/2023',103))                               \    
    )                                                                                                             \
     ##CONDAUX##                                                                                                  \
  ORDER BY                                                                                                        \
      CASE WHEN HR.QUAL_POSTO = 'ATUAL' THEN 1 ELSE 2 END, R034FUN.nomfun" ;                                      
  
}


TrocaString(ASQL,"##CONDAUX##" , aConAux,ASQL);                                        
