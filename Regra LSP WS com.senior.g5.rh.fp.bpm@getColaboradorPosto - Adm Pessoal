  getColaboradorPosto.colaboradores.centrocusto = aCodCcu +  " - " + aNomCcu ;
  ConverteMascara (3,dDatAfa, aDAtAfa, "DD/MM/YYYY");
  @campo do bom é tipo data enviar sem data quando for zero@
  Se (dDatAfa > 0)
      getColaboradorPosto.colaboradores.datAfa = aDAtAfa ;
      
   getColaboradorPosto.colaboradores.sitafa =  aDesSit;
   getColaboradorPosto.colaboradores.horsem =  aHorSem ;
   getColaboradorPosto.colaboradores.hormes =  aHorMes ; 
