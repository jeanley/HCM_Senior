definir alfa cur_nivsal;
definir alfa asql_nivsal;
definir alfa aclasal;
definir alfa aestsal;
definir alfa acodapf;

definir data ddataatu;

definir alfa aseqniv;
definir alfa anivsal;
definir alfa avalsal;
Definir Alfa aClaSal;

definir numero nestsal;
definir numero ncodapf;
Definir Alfa aNumEmp;
Definir Alfa aCodFil;
Definir Alfa aValSal;
Definir Alfa aMotivo ;
Definir Alfa aTipCon;
Definir Alfa aForAtu;
Definir Cursor cR076DES ;

definir cursor cur_clasal;

ddataatu = datsis;

acodapf = getNivSal.ecodapf;
aestsal = getNivSal.ecodest;
aMotivo =   getNivSal.Motivo;
aTipCon =  getNivSal.tipcon;

aNumEmp =   getNivSal.numemp ;
aCodFil =   getNivSal.codfil ;

alfaparaint(aestsal, nestsal);
alfaparaint(acodapf, ncodapf);

AlfaParaint(aNumEmp,nNumEmp);
AlfaParaint(aCodFil,nCodFil);

nConNum = VerificaNumeroAlfa(aTipCon);

/*Se (nConNum = 1) {

  Se (aTipCon = "10")
    aForAtu = "D";
  Senao 
