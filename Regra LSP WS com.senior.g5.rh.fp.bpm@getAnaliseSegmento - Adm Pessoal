Funcao CarregaSql(Numero pTipSql); {


/*
   O SQL CRIAR NÃO ACEITA O comando  WITH  
   par trazes os empates de centro de custo
   faria apenas o WITH TOP 1 
   ai tratei dentro de uma subqueri pegndo os mairos qtd  WHERE QTD = ( .....
   

*/          

Se (pTipSql = 1) {
                     
    aComSql = "SELECT                                                                                   \
                  U.CODCCU,                                                                             \
                  U.QTD AS QTDSEG,                                                                      \
                  CASE                                                                                  \
                      WHEN U.CODCCU = F.CODCCU THEN 'MESMO SEGMENTO'                                    \
                      ELSE 'ALTERAÇÃO SEGMENTO'                                                         \
                  END AS OBSSEG                                                                         \
              FROM (                                                                                    \
                                                                                                        \
                  SELECT CODCCU, COUNT(*) AS QTD                                                        \
                  FROM (                                                                                \
                      SELECT CCU.CODCCU                                                                 \
                      FROM R020RAT RAT                                                                  \
                      INNER JOIN R018CCU CCU                                                            \
                          ON CCU.CODRAT = RAT.CODRAT                                                    \
                      WHERE CCU.NUMEMP = :NUMEMP                                                        \
                        AND RAT.CODRAT IN  "+ aCondRat +"                                                           \
                      UNION ALL                                                                         \
                      SELECT CCU.CODCCU                                                                 \
                      FROM R171APF APF                                                                  \
                      INNER JOIN R018CCU CCU                                                            \
                          ON CCU.NUMEMP = APF.NUMEMP                                                    \
                         AND CCU.CODRAT = APF.CODRAT                                                    \
                      WHERE APF.NUMEMP = :NUMEMP                                                        \
                        AND APF.TIPCOL = :TIPCOL                                                        \
                        AND APF.NUMCAD = :NUMCAD                                                        \
                        AND APF.CODAPF NOT IN  "+ aCondEnc +"                                                       \
                        AND (APF.DATFIM =  CONVERT(DATE, '31/12/1900', 103) OR APF.DATFIM > getdate())  \
                  ) T                                                                                   \
                  GROUP BY CODCCU                                                                       \
              ) AS U                                                                                    \
              CROSS JOIN (                                                                              \
                                                                                                        \
                  SELECT MAX(QTD) AS MAXQTD                                                             \
                  FROM (                                                                                \
                      SELECT CODCCU, COUNT(*) AS QTD                                                    \
                      FROM (                                                                            \
                          SELECT CCU.CODCCU                                                             \
                          FROM R020RAT RAT                                                              \
                          INNER JOIN R018CCU CCU                                                        \
                              ON CCU.CODRAT = RAT.CODRAT                                                \
                          WHERE CCU.NUMEMP = :NUMEMP                                                          \
                            AND RAT.CODRAT IN  "+ aCondRat +"                                                        \
                                                                                                        \
                          UNION ALL                                                                     \
                                                                                                        \
                          SELECT CCU.CODCCU                                                             \
                          FROM R171APF APF                                                              \
                          INNER JOIN R018CCU CCU                                                        \
                              ON CCU.NUMEMP = APF.NUMEMP                                                \
                             AND CCU.CODRAT = APF.CODRAT                                                \
                          WHERE APF.NUMEMP = :NUMEMP                                                          \
                            AND APF.TIPCOL = :TIPCOL                                                          \
                            AND APF.NUMCAD = :NUMCAD                                                   \
                            AND APF.CODAPF NOT IN "+ aCondEnc +"                                       \
                            AND (APF.DATFIM = CONVERT(DATE, '31/12/1900', 103) OR APF.DATFIM > getdate()) \
                      ) T                                                                                 \
                      GROUP BY CODCCU                                                                     \
                  ) B                                                                                     \
              ) AS M                                                                                      \
              LEFT JOIN R034FUN AS F                                                                      \
                  ON F.NUMEMP = :NUMEMP                                                                         \
                 AND F.TIPCOL = :TIPCOL                                                                         \
                 AND F.NUMCAD = :NUMCAD                                                                  \
              WHERE                                                                                       \
                                                                                                          \
                  U.QTD = M.MAXQTD";
                              
                
    }
    Senao  se (pTipSql =2) {
       aComSql = "SELECT                                                       \
                      POS.ESTPOS,                                              \
                      POS.DESPOS,                                              \
                      CAR.CODCAR,                                               \
                      POS.POSTRA                                                \
                  FROM                                                         \
                      R017CAR AS CAR,                                          \
                      R030POS AS EPO,                                          \
                      R017POS AS POS                                           \
                  WHERE                                                        \
                      CAR.CODCCU IN "+aCondCcu+"                     \
                      AND CAR.NUMEMP = :NUMEMP                                       \
                      AND CAR.CODFIL = :CODFIL                                    \
                      AND CAR.TIPCON = 10                                        \
                      AND EPO.NUMEMP = CAR.NUMEMP                              \
                      AND EPO.DATALT = (                                       \
                          SELECT MAX(TAB.DATALT)                               \
                          FROM R030POS AS TAB                                  \
                          WHERE TAB.NUMEMP = CAR.NUMEMP                        \
                      )                                                        \
                      AND CAR.ESTPOS = EPO.ESTPOS                              \
                      AND (                                                    \
                          CAR.DATFIM > :DATATU                               \
                          OR CAR.DATFIM = :DATZER                            \
                      )                                                        \
                      AND CAR.DATINI = (                                       \
                          SELECT MAX(TAB2.DATINI)                              \
                          FROM R017CAR AS TAB2                                 \
                          WHERE TAB2.ESTPOS = CAR.ESTPOS                       \
                            AND TAB2.POSTRA = CAR.POSTRA                       \
                            AND (                                              \
                                TAB2.DATFIM > :DATATU                        \
                                OR TAB2.DATFIM > :DATZER                     \
                            )                                                  \
                      )                                                        \
                      AND POS.ESTPOS = CAR.ESTPOS                              \
                      AND POS.POSTRA = CAR.POSTRA";                            
                      
    }
    Senao {
        Definir Alfa aSqlPrin ;
        
        aSqlPrin = "SELECT APF.CODRAT, \
                           APF.HORMES FROM r171APF APF    \
                            WHERE APF.NUMEMP = :NUMEMP  \
                              AND APF.TIPCOL = :TIPCOL   \
                              AND APF.NUMCAD = :NUMCAD \
                              AND APF.codapf NOT IN "+ aCondAti +"       \
                              AND APF.codapf not IN "+ aCondEnc +"  \
                              AND (APF.DATFIM =  CONVERT(DATE, '31/12/1900', 103) OR APF.DATFIM > getdate())" ;
                                    
         aComAlt = "   \
                  SELECT                    \
                      APF.CODRAT,           \
                      TAB1.HORMES           \
                  FROM (                    \
                      ##SQLALT##            \
                  ) AS TAB1                 \
                  INNER JOIN R171APF AS APF  \
                      ON TAB1.CODAPF = APF.CODAPF \
                  WHERE APF.NUMEMP = :NUMEMP            \
                    AND APF.TIPCOL = :TIPCOL            \
                    AND APF.NUMCAD = :NUMCAD           \
                    AND (APF.DATFIM =  CONVERT(DATE, '31/12/1900', 103) OR APF.DATFIM > getdate())"   ;
                    
                    
        aSqlAux =  aSqlPrin ;
       
        Se  (nQtdAlt > 0) {
           TrocaString(aComAlt, "##SQLALT##", aSqlAlt, aComAlt);
           aSqlAux = aSqlAux  + " " +  " UNION ALL " +  aComAlt;  
    
        }
        Se (nQtdIns > 0) {
           @Se (nQtdIns = 1) @
           aSQlIns = " UNION ALL " +  aSQlIns;
               
           aSqlAux = aSqlAux  + " " +   aSQlIns ;
        } 
        
        aComSql = "SELECT                                      \                                                    
                      Q.CODRAT,                            \
                      SUM(Q.HORMES) AS TOTAL_HORAS,        \
                      FUN.ESTPOS,                          \
                      FUN.POSTRA,                          \
                      FUN.CODCCU       AS CODCCU_FUN,      \
                      CCU.CODCCU       AS CODCCU,   \
                      CASE                                 \
                          WHEN FUN.CODCCU = CCU.CODCCU      \
                              THEN 'SEM ALTERAÇÃO DE SEGMENTO' \
                          ELSE 'ALTERAÇÃO SEGMENTO'      \
                      END AS OBSSEG                         \
                  FROM (                                    \
                     #SQLAUX#                                  \
                  ) AS Q                                    \
                  INNER JOIN R034FUN AS FUN                 \
                      ON FUN.NUMEMP = :NUMEMP                     \
                     AND FUN.TIPCOL = :TIPCOL                      \
                     AND FUN.NUMCAD = :NUMCAD               \
                  INNER JOIN R018CCU AS CCU                  \
                      ON CCU.NUMEMP = FUN.NUMEMP             \
                     AND CCU.CODRAT = Q.CODRAT                \
                  GROUP BY                                    \
                      Q.CODRAT,                               \
                      FUN.ESTPOS,                             \
                      FUN.POSTRA,                              \
                      FUN.CODCCU,                              \
                      CCU.CODCCU                               \
                  HAVING                                       \
                      SUM(Q.HORMES) = (                        \
                          SELECT MAX(TOTAL)                     \
                          FROM (                                \
                              SELECT                            \
                                  SUM(Q2.HORMES) AS TOTAL       \
                              FROM (                            \
                                  #SQLAUX#                          \
                              ) AS Q2                           \
                              GROUP BY Q2.CODRAT              \
                          ) AS T                       \
                      )";   
        
        
        TrocaString(aComSql,"#SQLAUX#",aSqlAux,aComSql);        
    }                                                                             
}



