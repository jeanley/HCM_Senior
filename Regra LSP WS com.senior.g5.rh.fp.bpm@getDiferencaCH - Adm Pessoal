{
  getDiferencaCH.sindicato = "Ultrapassou Limite de Carga Horária";
}
se(ntotalsemana <= nhorsemsin)
{
  getDiferencaCH.sindicato = "Dentro do Limite de Carga Horária";
}
@ntotalmes = ntotalsemana * 4.5;@

convertemascara(4, ntotalsemana, atotalsemana, "hh:mm");
convertemascara(4, ntotalmes, atotalmes, "hh:mm");

