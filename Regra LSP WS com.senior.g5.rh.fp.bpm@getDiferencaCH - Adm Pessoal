nhorsem = 0;
nhormes = 0;
ntotalsemana = 0;
ntotalmes = 0;

cur_totalizador.sql"select usu_horsem, usu_hormes              \
               from usu_tempch2                                \
               where                                           \
               usu_numemp = :anumemp and                       \
               usu_tipcol = :atipcol and                       \
               usu_numcad = :anumcad";
               
cur_totalizador.abrircursor();
enquanto(cur_totalizador.achou)
{
  nhorsem = cur_totalizador.usu_horsem;
  nhormes = cur_totalizador.usu_hormes;
    
  ntotalsemana = ntotalsemana + nhorsem;
  ntotalmes = ntotalmes + nhormes;
  cur_totalizador.proximo();
}
cur_totalizador.fecharcursor();                     

@Verifica se teve redução de CH@
se(ntotalsemana < nhorsematu)
{
  getDiferencaCH.reducao = "Teve Tedução";
}
se(ntotalsemana >= nhorsematu)
{
  getDiferencaCH.reducao = "Não Teve Tedução";
}

@Verifica se Ultrapassou limite do Sindicato@
