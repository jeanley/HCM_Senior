@ Declaração de variáveis @
DEFINIR ALFA ASQL;
DEFINIR ALFA ACURSOR;
DEFINIR ALFA AFLUXO;
DEFINIR ALFA ADTSOLI;
DEFINIR ALFA ADTEFET;
DEFINIR ALFA ANUMEMP;
DEFINIR ALFA ACOMPET;
DEFINIR ALFA ASOLPER;
DEFINIR ALFA AEFEPER;
DEFINIR DATA DDTSOLI;



@ Atribuição de valores @
AFLUXO  = getPeriodo.efluxo;
ADTSOLI = getPeriodo.edatasolicitacao;
ADTEFET = getPeriodo.edataefetivacao;
DDTSOLI = datsis;       
ConverteMascara (3,DDTSOLI,ADTSOLI,"YYYY-MM-DD");  
ANUMEMP = getPeriodo.enumemp;

@ ############################################################################ @
@ FLUXO DE MOVIMENTAÇÃO @
@ ############################################################################ @
SE (AFLUXO = "movimentacao")                  
{
  @ SOLICITAÇÃO @
  SE(ADTSOLI <> "")
  {
    @ Competências @
    @ 103 - Estilo da data em DD/MM/YYYY @
    ASQL= "SELECT USU_NUMEMP,                                                     \
            FORMAT(CONVERT(DATE, USU_COMPET, 103), 'MM/yyyy') AS USU_COMPET       \
            FROM USU_TBPM_PER                                                     \
            WHERE                                                                 \
            USU_NUMEMP = :NUMEMP                                                  \  
            AND                                                                   \
                   (                                                              \
                usu_solmov_ini >= :DTSOLI                                         \
                OR usu_solmov_fim >= :DTSOLI) ";                                


  
    SQL_CRIAR(ACURSOR);
    SQL_USARABRANGENCIA(ACURSOR,0);
    SQL_USARSQLSENIOR2(ACURSOR,0);
    SQL_DEFINIRCOMANDO(ACURSOR,ASQL);
    SQL_DEFINIRALFA(ACURSOR,"NUMEMP",ANUMEMP); 
    SQL_DEFINIRALFA(ACURSOR,"DTSOLI",ADTSOLI);
    SQL_ABRIRCURSOR(ACURSOR);
    ENQUANTO(SQL_EOF(ACURSOR) = 0)
    {
      SQL_RETORNARALFA(ACURSOR,"usu_compet",ACOMPET);
      SQL_RETORNARALFA(ACURSOR,"USU_NUMEMP",ANUMEMP);
  	
    	@ CRIANDO LINHA @
      getPeriodo.solicitacao.CRIARLINHA();
      getPeriodo.solicitacao.scompetencia = ACOMPET;
      getPeriodo.solicitacao.sempresa = ANUMEMP;
    	
    	SQL_PROXIMO(ACURSOR);
    }
    SQL_FECHARCURSOR(ACURSOR);
    SQL_DESTRUIR(ACURSOR); 
    
    @ Data é permitida ? @
    ASQL= "SELECT usu_compet                                                    \
            FROM USU_TBPM_PER                                                   \
            WHERE :DTSOLI                                                       \
              BETWEEN usu_solmov_ini                                            \
              AND usu_solmov_fim                                                \  
              AND USU_NUMEMP = :NUMEMP ";                                
  
    SQL_CRIAR(ACURSOR);
    SQL_USARABRANGENCIA(ACURSOR,0);
    SQL_USARSQLSENIOR2(ACURSOR,0);
    SQL_DEFINIRCOMANDO(ACURSOR,ASQL);
    SQL_DEFINIRALFA(ACURSOR,"NUMEMP",ANUMEMP); 
    SQL_DEFINIRALFA(ACURSOR,"DTSOLI",ADTSOLI);
    SQL_ABRIRCURSOR(ACURSOR);
    SE(SQL_EOF(ACURSOR) = 0)
    {
      ASOLPER = "S";      
    }
    SENAO
    {
      ASOLPER = "N";
    }
    SQL_FECHARCURSOR(ACURSOR);
    SQL_DESTRUIR(ACURSOR);
    
    getPeriodo.ssolicitacaopermitida = ASOLPER;
  }
  
  
  @ EFETIVAÇÃO @
  SE(ADTEFET <> "")
  {
    ASQL= "SELECT                                                                 \
            FORMAT(CONVERT(DATE, USU_COMPET, 103), 'MM/yyyy') AS USU_COMPET       \
            FROM USU_TBPM_PER                                                     \
            WHERE                                                                \
            USU_NUMEMP = :NUMEMP                                                  \
                        AND                                                       \                                                    
                (usu_efemov_ini >= :DTEFET                                         \
                OR usu_efemov_fim >= :DTEFET) ";                                

    SQL_CRIAR(ACURSOR);
    SQL_USARABRANGENCIA(ACURSOR,0);
    SQL_USARSQLSENIOR2(ACURSOR,0);
    SQL_DEFINIRCOMANDO(ACURSOR,ASQL);
    SQL_DEFINIRALFA(ACURSOR,"NUMEMP",ANUMEMP);
    SQL_DEFINIRALFA(ACURSOR,"DTEFET",ADTEFET);
    SQL_ABRIRCURSOR(ACURSOR);
    ENQUANTO(SQL_EOF(ACURSOR) = 0)
    {
      SQL_RETORNARALFA(ACURSOR,"usu_compet",ACOMPET);
  	
    	@ CRIANDO LINHA @
      getPeriodo.efetivacao.CRIARLINHA();
      getPeriodo.efetivacao.scompetencia = ACOMPET;
    	
    	SQL_PROXIMO(ACURSOR);
    }
    SQL_FECHARCURSOR(ACURSOR);
    SQL_DESTRUIR(ACURSOR);
    
    @ Data é permitida ? @
    ASQL= "SELECT usu_compet                                                    \
            FROM USU_TBPM_PER                                                   \
            WHERE :DTEFET                                                       \
              BETWEEN usu_efemov_ini                                            \
              AND usu_efemov_fim                                                \
              AND USU_NUMEMP = :NUMEMP ";                                        
  
    SQL_CRIAR(ACURSOR);
    SQL_USARABRANGENCIA(ACURSOR,0);
    SQL_USARSQLSENIOR2(ACURSOR,0);
    SQL_DEFINIRCOMANDO(ACURSOR,ASQL);
    SQL_DEFINIRALFA(ACURSOR,"NUMEMP",ANUMEMP);
    SQL_DEFINIRALFA(ACURSOR,"DTEFET",ADTEFET);
    SQL_ABRIRCURSOR(ACURSOR);
    SE(SQL_EOF(ACURSOR) = 0)
    {
      AEFEPER = "S";      
    }
    SENAO
    {
      AEFEPER = "N";
