Definir Alfa aSQL;                                              
Definir Alfa cBusca;
Definir Alfa aNumEmp;
Definir Alfa aTipCol;
Definir Alfa aNumCad;
Definir Alfa aNomFun;
Definir Alfa aCodFil;
Definir Alfa aEmaCom;
Definir Alfa aEmaPar;                                                                          
Definir Alfa aNumTel;
Definir Alfa aDatAdm;
Definir Alfa aNumCpf;
Definir Alfa aNomCCu ;
Definir alfa aCodCcu;

Definir Numero nNumEmp;
Definir Numero nTipCol;
Definir Numero nNumCad;
Definir Numero nCodFil;
Definir Data dDatAdm;
Definir Numero nCadSol ;
Definir Numero nFilSol ;

Definir Cursor Cur_BuscaPFil;

aNumEmp = getColaboradoresVF.enumemp;
aTipCol = getColaboradoresVF.etipcol;
aNumCad = getColaboradoresVF.enumcad;
aCodFil = getColaboradoresVF.ecodfil;
aNomFun = getColaboradoresVF.enomfun;
AlfaParaInt(aNumCad,nCadSol);
AlfaParaInt(aCodFil,nFilSol);                 

aTipCol = "1" ;

aSQL = "SELECT FUN.NUMEMP,                                                     \
               FUN.TIPCOL,                                                     \
               FUN.NUMCAD,                                                     \
               FUN.CODFIL,                                                     \
               FUN.CODCCU,                                                     \
               FUN.NOMFUN,                                                     \
               FUN.NUMCPF,                                                     \
               FUN.DATADM,                                                     \
               CPL.NUMTEL,                                                     \
               CPL.EMACOM,                                                     \
               CPL.EMAPAR,                                                       \
               CCU.NOMCCU                                                        \
                 FROM R034FUN FUN, R034CPL CPL , R018CCU CCU                   \
                   WHERE FUN.NUMEMP = CPL.NUMEMP                               \
                     AND FUN.TIPCOL = CPL.TIPCOL                               \
                     AND FUN.NUMCAD = CPL.NUMCAD                               \
                     AND FUN.NUMEMP = CCU.NUMEMP \                             \
                     AND FUN.CODCCU = CCU.CODCCU                               \
                     AND FUN.TIPCOL = 1 \
                     AND FUN.SITAFA <> 7";

Se((aNumEmp <> "") e (aNumEmp <> " "))
aSQL = aSQL + " AND FUN.NUMEMP = " + aNumEmp;

Se((aCodFil <> "") e (aCodFil <> " ")) {
  
   @essa condição é temporaria apenas para não travar  o processo, será reavalida as abrangencias de consutla dos solicitantes@
   Se ((nFilSol = 1041)  ou (nFilSol = 1012)) {
        aSQL = aSQL + " AND FUN.CODFIL in (1012,1041,1061)" ;
   }
   Senao {
       aSQL = aSQL + " AND FUN.CODFIL = " + aCodFil;
   }

}

Se((aNumCad <> "") e (aNumCad <> " "))
aSQL = aSQL + " AND FUN.NUMCAD = " + aNumCad;

Se((aTipCol <> "") e (aTipCol <> " "))
aSQL = aSQL + " AND FUN.TIPCOL = " + aTipCol;

Se((aNomFun <> "") e (aNomFun <> " "))
aSQL = aSQL + " AND FUN.NOMFUN LIKE '%" + aNomFun + "%'";

aSQL = aSQL + " ORDER BY NOMFUN";

SQL_Criar(cBusca);
SQL_UsarAbrangencia(cBusca, 0);
SQL_UsarSQLSenior2 (cBusca, 0);
SQL_DefinirComando (cBusca, aSQL);          

SQL_AbrirCursor(cBusca);

Enquanto(SQL_EOF(cBusca)=0)
{ 
  SQL_RetornarInteiro(cBusca, "NUMEMP", nNumEmp);
  SQL_RetornarInteiro(cBusca, "TIPCOL", nTipCol);
  SQL_RetornarInteiro(cBusca, "NUMCAD", nNumCad);
  SQL_RetornarInteiro (cBusca, "CODFIL", nCodFil);
  SQL_RetornarAlfa   (cBusca, "NOMFUN", aNomFun);
  SQL_RetornarInteiro(cBusca, "NUMCPF", nNumCpf);
  SQL_RetornarData   (cBusca, "DATADM", dDatAdm);
  SQL_RetornarAlfa   (cBusca, "NUMTEL", aNumTel);
  SQL_RetornarAlfa   (cBusca, "EMACOM", aEmaCom);
  SQL_RetornarAlfa   (cBusca, "EMAPAR", aEmaPar);  
  SQL_RetornarAlfa   (cBusca, "NOMCCU", aNomCcu);     
  SQL_RetornarAlfa   (cBusca, "CODCCU", aCodCcu);            
  
  ConverteMascara(1, nNumEmp, aNumEmp, "9[4]");
  ConverteMascara(1, nTipCol, aTipCol, "9[1]");
  ConverteMascara(1, nNumCad, aNumCad, "#N(9,0)[EDICAD]#");       
  ConverteMascara(1, nNumCpf, aNumCpf, "999.999.999-99");
  ConverteMascara(3, dDatAdm, aDatAdm, "DD/MM/YYYY");
  
  DescItemLista("LTipCol", aTipCol, aTipCol);
    
  getColaboradoresVF.sretorno.CriarLinha();  
  getColaboradoresVF.sretorno.snumemp = aNumEmp;
  getColaboradoresVF.sretorno.stipcol = aTipCol;
  getColaboradoresVF.sretorno.snumcad = aNumCad;
  getColaboradoresVF.sretorno.snomfun = aNomFun;
  getColaboradoresVF.sretorno.scodccu =  aCodCcu;
  getColaboradoresVF.sretorno.snomccu =  aNomCcu; 
  
  Cur_BuscaPFil.sql " SELECT                                                   \
                        USU_PorLancFil                                       \
                    FROM                                                     \
                        R030FIL                                              \
                    WHERE                                                    \
                        numemp = :nNumEmp                                    \
                    AND codfil = :nCodFil";

  Cur_BuscaPFil.abrircursor();
  Se(Cur_BuscaPFil.achou)
  {
      DEFINIR ALFA aPorcentagemFil;
      DEFINIR NUMERO nPorcentagemFil;                                                                                                    
      
      nPorcentagemFil = Cur_BuscaPFil.USU_PorLancFil;
      
      intparaalfa(nPorcentagemFil,aPorcentagemFil);
  
      getColaboradoresVF.sretorno.sporcenfil = aPorcentagemFil;
  }
  Cur_BuscaPFil.fecharcursor();
  
  SQL_Proximo(cBusca);
}
SQL_FecharCursor(cBusca);
SQL_Destruir(cBusca);
