    SQL_DEFINIRALFA(ACURSOR,"anumemp",anumemp);                                                            
    SQL_ABRIRCURSOR(ACURSOR);
    SE(SQL_EOF(ACURSOR) = 0)
    {
        getPeriodoAprovacao.smensagem = "Efetivação no período permitido.";        
        getPeriodoAprovacao.sretorno = "1";
        
    }
    SENAO
    {    
