definir alfa acomp;
definir alfa anumemp;
definir alfa ACURSOR;
definir alfa ASQL;
definir alfa adatcomp;                                      

definir data ddathoj;
definir data ddatzer;

ddathoj = datsis;                                                                  
@ddathoj = datsis + 6; @     
@MontaData(21,1,2025,ddathoj); @                   
                                                                   
acomp = getPeriodoAprovacao.ecomp;
anumemp = getPeriodoAprovacao.enumemp;                                                 

acomp = "01/"+acomp;                                                               

                                                                              
MONTADATA(31,12,1900,DDATZER);                                                               
ddatzer = 0;

   
    @ Data é permitida ? @
    ASQL= "SELECT *                                                            \
            FROM USU_TBPM_PER                                                  \             
            WHERE :ddathoj >= usu_efechd_ini AND                               \
            :ddathoj <= usu_efechd_fim AND                                     \
            usu_numemp = :anumemp";  @ Só existe a numEmp 1, 2 e 3 @                                                                        
 
    SQL_CRIAR(ACURSOR);
