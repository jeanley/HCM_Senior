       ========================================================= */
	DECLARE @NUMEMP            INT  = 2;
    DECLARE @TIPCOL            INT  = 1;
    DECLARE @DATA_INICIO_2026  DATE = '2026-01-01';
    DECLARE @DATA_FIM_2025     DATE = '2025-12-31';
    DECLARE @DATA_FIM_ABR_2026 DATE = '2026-04-30';

	SELECT *  
    INTO #TMP_APF
    FROM R171APF
    WHERE NUMEMP = 2
      AND (DATFIM >= CONVERT(DATE,'2026-01-01 00:00:00.000') or datfim = CONVERT(DATE,'1900-12-31 00:00:00.000')) AND DATINI <= CONVERT(DATE,'2025-12-31') 


    /* Encerrar atividade antiga em 31/12/2025 */
    UPDATE A
       SET A.DATFIM = convert(date,'2025-12-31')
    FROM R171APF A
    JOIN #TMP_APF T
      ON T.NUMEMP = A.NUMEMP
     AND T.TIPCOL = A.TIPCOL
     AND T.NUMCAD = A.NUMCAD
     AND T.DATINI = A.DATINI
     AND T.DATFIM = A.DATFIM
     AND T.CODAPF = A.CODAPF
     AND T.SEQAPF = A.SEQAPF;

    /* Preparar novas atividades com nova sequência */
    SELECT
        T.NUMEMP,
        T.TIPCOL,
        T.NUMCAD,
        CONVERT(DATE,'2026-01-01 00:00:00.000') AS DATINI,
        ISNULL
        (
            (
                SELECT MAX(X.SEQAPF)
                FROM R171APF X
                WHERE X.NUMEMP = T.NUMEMP
                  AND X.TIPCOL = T.TIPCOL
                  AND X.NUMCAD = T.NUMCAD
            ), 0
        )
        +
        ROW_NUMBER() OVER
        (
            PARTITION BY T.NUMEMP, T.TIPCOL, T.NUMCAD
            ORDER BY T.CODAPF, T.DATINI, T.SEQAPF
        ) AS NOVO_SEQAPF,
        T.DATFIM,
        T.CODAPF,
        D.CR_DYNAMICS AS CODRAT,
        T.MARPTO,
        T.HORMES,
        T.hormno,
        T.HORSEM,
        T.HORSNO,
        T.HORSEG,
        T.HORTER,
        T.HORQUA,
        T.HORQUI,
        T.HORSEX,
        T.HORSAB,
        T.HORDOM,
        T.ESTSAL,
        T.CLASAL,
        T.NIVSAL,
        T.REFAPF,
        T.VALAPF,
        T.ORIAPF,
        T.OBSAPF,
        T.USU_PAGRES,
        T.USU_CAURES,
        T.USU_ULTALT,
        T.USU_MOTRES,
        T.USU_INSBPM
    INTO #TMP_APF_NOVA
    FROM #TMP_APF T
    LEFT JOIN #DEPARA D
      ON D.CODIGO_RED_CR = T.CODRAT
    WHERE T.NUMEMP = 2
      AND D.CODIGO_RED_CR IS NOT NULL;

