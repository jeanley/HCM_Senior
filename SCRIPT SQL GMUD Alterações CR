    DECLARE @NUMEMP            INT  = 2;
    DECLARE @TIPCOL            INT  = 1;
    DECLARE @DATA_INICIO_2026  DATE = '2026-01-01';
    DECLARE @DATA_FIM_2025     DATE = '2025-12-31';
    DECLARE @DATA_FIM_ABR_2026 DATE = '2026-04-30';

    SELECT DISTINCT
        A.NUMEMP,
        A.TIPCOL,
        A.NUMCAD,
        H.SITAFA,
        H.DATAFA
    INTO #LISTA_COLABORADORES
    FROM R034FUN A WITH (NOLOCK)
    LEFT JOIN R038AFA H
        ON H.NUMEMP = A.NUMEMP
       AND H.TIPCOL = A.TIPCOL
       AND H.NUMCAD = A.NUMCAD
       AND H.SITAFA IN (7,18)
    LEFT JOIN R018CCU J
        ON J.NUMEMP = A.NUMEMP
       AND J.CODCCU = A.CODCCU
    WHERE A.NUMEMP = @NUMEMP
      AND A.TIPCOL = @TIPCOL
      AND (
            A.SITAFA NOT IN (7,18)
            OR (A.SITAFA IN (7,18) AND H.DATAFA >= @DATA_INICIO_2026)
          );	  

		  
		  
