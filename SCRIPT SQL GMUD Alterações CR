    /* =========================================================
       6. BLOCO B
          COLABORADORES COM ALTERAÇÕES ENTRE JAN E ABR/2026
       ========================================================= */
	DECLARE @NUMEMP            INT  = 2;
    DECLARE @TIPCOL            INT  = 1;
    DECLARE @DATA_INICIO_2026  DATE = '2026-01-01';
    DECLARE @DATA_FIM_2025     DATE = '2025-12-31';
    DECLARE @DATA_FIM_ABR_2026 DATE = '2026-04-30';

    ;WITH MOV_2026 AS
    (
        SELECT
            H.NUMEMP,
            H.TIPCOL,
            H.NUMCAD,
            H.DATALT,
            H.CODCCU AS CODCCU_ANTIGO,
            D.CR_DYNAMICS AS CODCCU_NOVO,
            ROW_NUMBER() OVER
            (
                PARTITION BY H.NUMEMP, H.TIPCOL, H.NUMCAD, H.DATALT
                ORDER BY H.DATALT, H.CODCCU
            ) AS RN
        FROM R038HCC H
        JOIN #DEPARA D
            ON D.CODIGO_RED_CR = H.CODCCU
        JOIN #LISTA_COLABORADORES L
            ON L.NUMEMP = H.NUMEMP
           AND L.TIPCOL = H.TIPCOL
           AND L.NUMCAD = H.NUMCAD
        WHERE H.NUMEMP = @NUMEMP
          AND H.TIPCOL = @TIPCOL
          AND H.DATALT BETWEEN @DATA_INICIO_2026 AND @DATA_FIM_ABR_2026
    )
    SELECT
        NUMEMP,
        TIPCOL,
        NUMCAD,
        DATALT,
        CODCCU_ANTIGO,
        CODCCU_NOVO
    INTO #TMP_R038HCC_BLOCO_B
    FROM MOV_2026
    WHERE RN = 1;

    /* Update do próprio histórico quando já existe registro no período */
    UPDATE H
       SET H.CODCCU = T.CODCCU_NOVO
    FROM R038HCC H
    JOIN #TMP_R038HCC_BLOCO_B T
      ON T.NUMEMP = H.NUMEMP
     AND T.TIPCOL = H.TIPCOL
     AND T.NUMCAD = H.NUMCAD
     AND T.DATALT = H.DATALT
    WHERE ISNULL(H.CODCCU, '') <> ISNULL(T.CODCCU_NOVO, '');		  
	
	
