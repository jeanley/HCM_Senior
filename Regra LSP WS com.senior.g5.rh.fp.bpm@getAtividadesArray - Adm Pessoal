Funcao RetornaSQLTIPO(); {

  aSQlAux ="" ;
  
  Se (aCodOpe = "Inserir") {
  
      aSQlAux =  "SELECT                                                  \
                ATI.CODAPF,                                                     \
                ATI.DESAPF,                                                     \
                NIV.VALSAL AS VALAPF,                                                    \
                0 AS HORSEM,                                                    \        
                0 AS HORMES,                                                     \
                0 AS SEQAPF,                                                     \
                CONVERT(DATE, '31/12/1900', 103) AS DATINI,                \
                ATI.USU_CODRAT  AS CODRAT, \
                RAT.DESRAT                                  \
            FROM                                                                \
                R171ATI ATI                                                     \
                                                                                \
                left JOIN R076CLA CLA                                          \
                    ON ATI.USU_CLASAL = CLA.CLASAL                               \
                   AND CLA.CODEST = :CODEST                                          \
                    AND cla.datalt = (SELECT MAX(TAB2.DATALT) FROM R076CLA TAB2     \
                    WHERE CLA.codest = TAB2.CODEST                                  \
                     AND  CLA.tipest = TAB2.TIPEST)                                 \
                left JOIN R020RAT RAT ON (ATI.USU_CODRAT =  RAT.CODRAT)            \                                                       
                left JOIN R076NIV NIV                                             \
                    ON NIV.CODEST = CLA.CODEST                                    \
                   AND NIV.TIPEST = CLA.TIPEST                                    \
                   AND NIV.DATALT = CLA.DATALT                                    \
                   AND NIV.SEQCLA = CLA.SEQCLA                                    \
                   AND NIV.TIPEST = 1                                             \
                   AND NIV.DATALT = (                                             \
                        SELECT MAX(TAB.DATALT)                                    \
                        FROM R076NIV TAB                                          \
                        WHERE                                                     \
                            NIV.CODEST = TAB.CODEST                               \
                            AND NIV.TIPEST = TAB.TIPEST                           \
                            AND NIV.SEQCLA = TAB.SEQCLA                           \
                            AND NIV.SEQNIV = TAB.SEQNIV                           \
                            AND TAB.DATALT <= :DATALT   \
                   )                                                              \
                   AND NIV.SEQNIV = (                                             \
                        SELECT MIN(TAB2.SEQNIV)                                   \
                        FROM R076NIV TAB2                                         \
                        WHERE                                                     \
                            TAB2.CODEST = NIV.CODEST                              \
                            AND TAB2.TIPEST = NIV.TIPEST                          \
                            AND TAB2.DATALT = NIV.DATALT                          \
                            AND TAB2.SEQCLA = NIV.SEQCLA                          \
                   )                                                              \
                                                                                  \
            WHERE                                                                 \
                (                                                                 \
                    ATI.FIMAPF = :DATZER                 \
                    OR ATI.FIMAPF > :DATALT             \
                )                                                                 \
                AND ATI.USU_CONBMP = 'S'                                          \
                AND (                                                             \
                       (:NUMEMP = 1 AND ATI.USU_CONE01 = 'S')                      \
                    OR (:NUMEMP = 2 AND ATI.USU_CONE02 = 'S')                      \
                    OR (:NUMEMP = 3 AND ATI.USU_CONE03 = 'S')                      \
                )                                                                 \
                AND NOT EXISTS (                                                  \
                    SELECT 1                                                      \
                    FROM R171APF APF ,R171ATI AT2                                                \
                    WHERE                                                         \
                        APF.NUMEMP =  :NUMEMP                                           \
                        AND APF.TIPCOL = :TIPCOL                                        \
                        AND APF.NUMCAD = :NUMCAD                                 \
                        AND ATI.CODAPF = APF.CODAPF                               \
                        AND APF.DATFIM = :DATZER                                 \
                        AND APF.DATINI <= :DATATU                                \
                        AND APF.codapf = AT2.codapf   \
                        AND (at2.usu_dutati = 'N' OR at2.usu_dutati is null OR  at2.usu_dutati = ''  ))" ;
                
  }
  Senao {
     aSQlAux = "SELECT ATI.CODAPF,                                   \
                       ATI.DESAPF,                                              \
                       APF.VALAPF,                                              \
                       ISNULL(NULLIF(APF.HORMES, 0) / 4.5, 0) AS HORSEM,        \
                       ISNULL(APF.HORMES, 0) AS HORMES,        \
                       APF.SEQAPF,                                   \
                       APF.DATINI,  \
                       APF.CODRAT, \
                       RAT.DESRAT   FROM R171APF APF \
                INNER JOIN R171ATI ATI ON (APF.CODAPF = ATI.CODAPF)             \
                 left JOIN R020RAT RAT ON (APF.CODRAT =  RAT.CODRAT)  \ 
                WHERE APF.NUMEMP = :NUMEMP \                                           \
                  AND APF.TIPCOL = :TIPCOL \                                           \
                  AND APF.NUMCAD = :NUMCAD \
                  AND (APF.DATFIM = :DATZER OR APF.DATFIM >= :DATATU ) \
                  AND APF.DATINI <= :DATATU";


  
  
  
  }


}   
