Funcao AtualizasCampos(Numero pTipAtu);{
  ATU_MsgReg = ""; 
  
  Se (pTipAtu = 1) {
    ExecSqlEx("                           \
        UPDATE R038HSA                    \
           SET USU_INSBPM = :nBpmId       \
         WHERE NUMEMP = :nNumEmp          \
           AND TIPCOL = :nTipCol          \
           AND NUMCAD = :nNumCad          \
           AND DATALT = :dDatMov          \
           AND CODMOT = :nCodMot          \
           AND SEQALT = 1                 \
         ",nErrSql,ATU_MsgReg);                             
  }
  Se (pTipAtu = 2) {
    ExecSqlEx("                           \
        UPDATE R038HPO                    \
           SET USU_INSBPM = :nBpmId       \
         WHERE NUMEMP = :nNumEmp          \
           AND TIPCOL = :nTipCol          \
           AND NUMCAD = :nNumCad          \
           AND INIATU = :dDatMov          \
           AND MOTALT = :nCodMot         \ 
           AND ESTPOS = :nEstDes         \
           AND POSTRA = :aPosDes        \
         ",nErrSql,ATU_MsgReg);  
  }
    
  Se (pTipAtu = 3) {
    ExecSqlEx("                           \
        UPDATE R038HES                    \
           SET USU_INSBPM = :nBpmId       \
         WHERE NUMEMP = :nNumEmp          \
           AND TIPCOL = :nTipCol          \
           AND NUMCAD = :nNumCad          \
           AND DATALT = :dDatMov          \
           AND CODESC = :nEscDes          \
         ",nErrSql,ATU_MsgReg);        
                                    
  }
}


Funcao CarregaAtividades(); {

   Definir Alfa aVarAux;
   Definir Alfa aCodAti;
   Definir Alfa aCodOpe;
   Definir Alfa aCodRat;
   Definir Alfa aSeqApf;
   Definir Numero nSeqApf;
   Definir Numero nHorSem;
   Definir Numero nVlrApf;
   Definir Alfa  aDatIni;
   Definir Data dDatIni;
   
   nQtdLin  = setMovimentaPessoal.atividades.QtdLinhas;
   nLinAtu  = 0 ;
   
   lstAtivdades.limpar();
    
   Enquanto (nLinAtu < nQtdLin) {
      setMovimentaPessoal.atividades.LinhaAtual = nLinAtu ;
      aCodOpe  = setMovimentaPessoal.atividades.lst_atividades_carga_horaria_nova_operara;
      aVarAux = setMovimentaPessoal.atividades.lst_atividades_carga_horaria_codigo1;
      ListaItem(aVarAux, "|", 2, aCodAti);
      ListaItem(aVarAux, "|", 3, aSeqApf);
      ListaItem(aVarAux, "|", 4, aDatIni);
     
   
      lstAtivdades.Adicionar();
      lstAtivdades.CodOpe =  aCodOpe;
      lstAtivdades.CodAti =  aCodAti ;             
      
      Se ((aCodOpe = "Inserir") ou (aCodOpe = "Alterar") ou (aCodOpe = "Encerrar")) {
         nHorSem =      setMovimentaPessoal.atividades.lst_atividades_carga_horaria_hora_decimal  ;   
         lstAtivdades.HorSem = nHorSem;
      
         Se (aCodOpe = "Inserir") {
            aVarAux=  setMovimentaPessoal.atividades.lst_atividades_carga_horaria_centro_de_custo1 ;  
            ListaItem(aVarAux, "-", 1, aCodRat);        
            lstAtivdades.CodRat = aCodRat ;
            
            aVarAux =  setMovimentaPessoal.atividades.lst_atividades_carga_horaria_valor_hora_1;
            AlfaParaInt(aVarAux,nVlrApf);
            lstAtivdades.VlrApf =  nVlrApf;    
         }
         Se ((aCodOpe = "Alterar") ou (aCodOpe = "Encerrar")) {
        
             AlfaParaint(aSeqApf,nSeqApf);
             AlfaParaData (aDatIni,"DD/MM/YYYY",dDatIni);
             lstAtivdades.SeqAti = nSeqApf;
             lstAtivdades.Datini = dDatIni;
         }   
    }      
    lstAtivdades.Gravar();   
    nLinAtu  ++;
    
   }
       
}


