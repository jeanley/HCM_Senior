MONTADATA(31,12,1900,DDATZER);
DDATHOJ = DATSIS;

@BUSCA ESTABILIDADES@
CBUSCA.SQL "SELECT CODETB, INIETB, FIMETB, OBSINI, OBSFIM FROM R038HEB WHERE NUMEMP = :NNUMEMP AND TIPCOL = :NTIPCOL AND NUMCAD = :NNUMCAD ORDER BY INIETB DESC"
CBUSCA.ABRIRCURSOR();
ENQUANTO(CBUSCA.ACHOU)
{
  NCODETB = CBUSCA.CODETB;
  INTPARAALFA(NCODETB,ACODETB);
  DESCITEMLISTA("LCODETB",ACODETB,ACODETB);
  DINIETB = CBUSCA.INIETB;
  CONVERTEMASCARA(3,DINIETB,AINIETB,"DD/MM/YYYY");
  DFIMETB = CBUSCA.FIMETB;  
  CONVERTEMASCARA(3,DFIMETB,AFIMETB,"DD/MM/YYYY");
  AOBSINI = CBUSCA.OBSINI;   
  AOBSFIM = CBUSCA.OBSFIM;
     
  AESTABILIDADE = AESTABILIDADE + "Data inicial: " + AINIETB + " Data final: "+ AFIMETB + " Estabilidade: "+ ACODETB + " Observação início: "+AOBSINI +" Observação fim: "+AOBSFIM + AENTER ;
  CBUSCA.PROXIMO();    
}
CBUSCA.FECHARCURSOR();
GETINFORESCISAO.ESTABILIDADE = "Estabilidades: " + AESTABILIDADE;

@BUSCA AFASTAMENTOS@
ASQL = "SELECT DATAFA, DATTER, DESSIT FROM R038AFA, R010SIT WHERE NUMEMP = :NNUMEMP AND TIPCOL = :NTIPCOL AND NUMCAD = :NNUMCAD \
 AND R038AFA.SITAFA IN (23,3) AND R010SIT.CODSIT = R038AFA.SITAFA ORDER BY DATAFA DESC";
 
SQL_CRIAR(CGEN);
SQL_USARSQLSENIOR2(CGEN,0);
SQL_USARABRANGENCIA(CGEN,0);
SQL_DEFINIRCOMANDO(CGEN,ASQL);
SQL_DEFINIRINTEIRO(CGEN,"NNUMEMP",NNUMEMP);
SQL_DEFINIRINTEIRO(CGEN,"NTIPCOL",NTIPCOL);
SQL_DEFINIRINTEIRO(CGEN,"NNUMCAD",NNUMCAD);
SQL_ABRIRCURSOR(CGEN); 
ENQUANTO(SQL_EOF(CGEN)=0  )
{
  
  SQL_RETORNARDATA(CGEN,"DATAFA",DDATAFA);
  SQL_RETORNARDATA(CGEN,"DATTER",DDATTER);
  SQL_RETORNARALFA(CGEN,"DESSIT",ADESSIT);
  CONVERTEMASCARA(3,DDATAFA,ADATAFA,"DD/MM/YYYY");
  CONVERTEMASCARA(3,DDATTER,ADATTER,"DD/MM/YYYY");       
  AAFASTAMENTOS = AAFASTAMENTOS + "Data inicial: " + ADATAFA + " Data final: "+ ADATTER + " Motivo: "+ ADESSIT + AENTER ;
  SQL_PROXIMO(CGEN);    
}
SQL_FECHARCURSOR(CGEN);
SQL_DESTRUIR(CGEN);
GETINFORESCISAO.AFASTAMENTOS = "Afastamentos: " + AAFASTAMENTOS; 

@BUSCA ANOTACOES@
ASQL = "SELECT DATNOT, NOTFIC, DESNOT FROM R038NOT, R022NOT WHERE NUMEMP = :NNUMEMP AND TIPCOL = :NTIPCOL AND NUMCAD = :NNUMCAD \
 AND R038NOT.TIPNOT IN (16) AND R022NOT.CODNOT = R038NOT.TIPNOT ORDER BY DATNOT DESC";
 
SQL_CRIAR(CGEN);
SQL_USARSQLSENIOR2(CGEN,0);
SQL_USARABRANGENCIA(CGEN,0);
SQL_DEFINIRCOMANDO(CGEN,ASQL);
SQL_DEFINIRINTEIRO(CGEN,"NNUMEMP",NNUMEMP);
SQL_DEFINIRINTEIRO(CGEN,"NTIPCOL",NTIPCOL);
SQL_DEFINIRINTEIRO(CGEN,"NNUMCAD",NNUMCAD);
SQL_ABRIRCURSOR(CGEN); 
