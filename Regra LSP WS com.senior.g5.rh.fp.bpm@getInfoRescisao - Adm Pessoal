{
  
  SQL_RETORNARDATA(CGEN,"DATNOT",DDATNOT);
  SQL_RETORNARALFA(CGEN,"NOTFIC",ANOTFIC);
  SQL_RETORNARALFA(CGEN,"DESNOT",ADESNOT);
  CONVERTEMASCARA(3,DDATNOT,ADATNOT,"DD/MM/YYYY");       
  AANOTACOES = AANOTACOES + "Data : " + ADATNOT + " Tipo : "+ ADESNOT + " Anotação: "+ ANOTFIC + AENTER ;
  SQL_PROXIMO(CGEN);    
}
SQL_FECHARCURSOR(CGEN);
SQL_DESTRUIR(CGEN);
GETINFORESCISAO.ANOTACOES = AANOTACOES; 

@BUSCA HISTORICO DE CARGO@
