                      SELECT codeve                                \
                      FROM r008evc                                 \
                      WHERE usu_eveats = 'S'                       \
                  )                                                \
                  AND r046ver.numcad = :anumcad                    \
              GROUP BY                                             \
                  r046ver.numcad,                                  \
                  r046ver.tipcol,                                  \    
                  r046ver.numemp";   */
                  
    asql_eveats = " SELECT                                                     \
    r.numcad,                                                                  \
    r.tipcol,                                                                  \
    r.numemp,                                                                  \
    SUM(r.valeve) AS total_eventos_ats                                         \
FROM                                                                           \
    r046ver r                                                                  \
    INNER JOIN r044cal c                                                       \
        ON r.codcal = c.codcal                                                 \
        AND c.tipcal IN (11, 12, 13)                                           \
        AND c.perref = :dmesanteior                                            \
        AND c.numemp = r.numemp                                                \
    INNER JOIN r008evc e                                                       \
        ON r.codeve = e.codeve                                                 \
        AND e.usu_eveats = 'S'                                                 \
WHERE                                                                          \
    r.numcad = :anumcad                                                        \
GROUP BY                                                                       \
    r.numcad,                                                                  \
    r.tipcol,                                                                  \
    r.numemp";
    
    
    Sql_usarSqlSenior2(cur_eveats, 0);
    Sql_usarAbrangencia(cur_eveats, 0);
    
    Sql_DefinirComando(cur_eveats, asql_eveats);
    
    Sql_DefinirData(cur_eveats, "dmesanteior", dmesanteior);
    Sql_DefinirAlfa(cur_eveats, "anumcad", anumcad);
    
    Sql_AbrirCursor(cur_eveats);
    
    
    Enquanto(Sql_EOF(cur_eveats) = 0)
    {
      Sql_RetornarAlfa(cur_eveats, "total_eventos_ats", atotaleveats);
    
      Sql_Proximo(cur_eveats);
    }                                                                                
    
    Sql_FecharCursor(cur_eveats);
    Sql_Destruir(cur_eveats);

    getColabConcat.tretorno.svalats = atotaleveats;

  /*
